* text=auto

# Keep GitHub Linguist focused on the Go CLI implementation.
*.go linguist-detectable=true

# Exclude the website, docs, branding, and repo management files from language stats.
web/** linguist-generated=true
docs/** linguist-generated=true
branding/** linguist-generated=true
.github/** linguist-generated=true

# Exclude documentation and support content.
*.md linguist-documentation=true
LICENSE linguist-documentation=true
AGENTS.md linguist-documentation=true

# Exclude build, config, and metadata files from language breakdowns.
*.svg linguist-generated=true
*.toml linguist-generated=true
*.yaml linguist-generated=true
*.yml linguist-generated=true
*.sh linguist-generated=true
*.ps1 linguist-generated=true
*.txt linguist-generated=true
*.out linguist-generated=true
Makefile linguist-generated=true
.codeyeignore linguist-generated=true
.gitignore linguist-generated=true
.gitattributes linguist-generated=true
